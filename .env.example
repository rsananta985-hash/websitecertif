# CertyChain AI - Environment Configuration
# Copy this file to .env and fill in the values

# ── Database ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=certychain2024
MYSQL_DB=certychain_db
MYSQL_USER=certychain
MYSQL_PASSWORD=certychain_pass

# ── JWT Secret (CHANGE THIS IN PRODUCTION!) ──────────────────────────────────
JWT_SECRET=certychain-enterprise-secret-CHANGE-ME-IN-PRODUCTION

# ── Blockchain ───────────────────────────────────────────────────────────────
# Local development (Hardhat)
BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# For production (Polygon Mumbai testnet example):
# BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
# PRIVATE_KEY=your_production_private_key_here
# CONTRACT_ADDRESS=your_deployed_contract_address

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# Development:
CORS_ORIGIN=http://localhost:80,http://localhost:3000,http://localhost:5173
# Production (replace with your actual domain):
# CORS_ORIGIN=https://certychain.appskep.id

# ── Frontend API URL ─────────────────────────────────────────────────────────
# Development:
VITE_API_URL=http://localhost:8080/api
# Production:
# VITE_API_URL=https://api.certychain.appskep.id/api
